# ══════════════════════════════════════════════════════════════════════════════
#  VSV WebHook BOT — приклад конфігурації середовища (.env.example)
# ──────────────────────────────────────────────────────────────────────────────
#  • Скопіюй у `.env` та заповни плейсхолдери <...> реальними значеннями.
#  • `.env` НІКОЛИ не комітити в git (тримай у .gitignore). Комітиться лише
#    цей `.env.example` з плейсхолдерами.
#  • Генерація випадкових секретів на сервері:
#        openssl rand -hex 32       # ключі підпису / API-ключі
#        openssl rand -base64 24    # паролі (БД, адмін)
# ══════════════════════════════════════════════════════════════════════════════


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  1. ЛОГІН У ПАНЕЛЬ  (цим акаунтом заходиш у бота)                           ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# E-mail bootstrap-адміна: при старті цей акаунт створюється/підвищується до адміна.
ADMIN_EMAIL=<твій_email>

# Пароль адміна. ⚠️ Мінімум 16 символів (літери+цифри+символи). НЕ повторюй його
# в інших параметрах (зокрема в паролі БД нижче).
ADMIN_PASSWORD=<сильний_пароль_адміна>

# Підпис сесій/токенів авторизації (головний ключ auth). Зміна → розлогінить усіх.
# openssl rand -hex 32
AUTH_SECRET_KEY=<hex32_випадковий>


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  2. COOKIE / FLASK                                                          ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Cookie лише по HTTPS: 0 поки доступ по http://IP (інакше не залогінишся),
# 1 — ОБОВ'ЯЗКОВО коли підключиш HTTPS/домен.
FLASK_COOKIE_SECURE=0

# app.secret_key — підпис Flask-cookie. ⚠️ МАЄ бути ОКРЕМИМ випадковим значенням,
# НЕ таким самим, як ENCRYPTION_KEY (різні задачі — різні секрети!).
# openssl rand -hex 32
FLASK_SECRET_KEY=<hex32_випадковий_ІНШИЙ>

# (опційно) Тривалість сесії в секундах. За замовч. 7 діб (604800).
# SESSION_LIFETIME_SEC=604800


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  3. БІРЖА  ⚠️ НАЙВИЩИЙ РИЗИК — ключі керують коштами                        ║
# ╚════════════════════════════════════════════════════════════════════════════╝
#  Права ключів: ТІЛЬКИ Trade, БЕЗ Withdraw. Обов'язково IP-whitelist на IP VDS.
#  Якщо ключ колись засвітився — переви́пусти на біржі й онови тут.

# Bybit — реальна торгівля.
BYBIT_API_KEY=<bybit_key>
BYBIT_API_SECRET=<bybit_secret>

# Binance — дані/LIQMAP (достатньо read-only).
BINANCE_API_KEY=<binance_key>
BINANCE_API_SECRET=<binance_secret>


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  4. TELEGRAM                                                                ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Токен бота від @BotFather.
TELEGRAM_BOT_TOKEN=<telegram_bot_token>

# Твій особистий chat-id для приватних сповіщень.
TELEGRAM_CHAT_ID=<твій_chat_id>

# id групи-форуму (формат -100…) для тем/сповіщень. Порожньо = вимкнено.
TELEGRAM_FORUM_CHAT=<-100...>


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  5. ШИФРУВАННЯ                                                              ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Fernet-ключ, яким зашифровані збережені креденшели в БД.
# ⚠️ МАЄ лишатись ТОЧНО той самий, що використовувався на Render — інакше бот
#    не розшифрує перенесені дані. НЕ генеруй новий і НЕ прирівнюй до FLASK_SECRET_KEY.
ENCRYPTION_KEY=<той_самий_ключ_що_на_Render>


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  6. ЗОВНІШНІ СЕРВІСИ / ІНШЕ                                                 ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# CoinGecko (метадані монет). Порожньо = free-ліміти.
COINGECKO_API_KEY=<coingecko_key>

# GEMINI_API_KEY — у коді НЕ використовується (мертвий параметр). Можна не додавати.
# GEMINI_API_KEY=

# Посилання на інфо-сайт (показ у боті/Telegram).
INFO_SITE_URL=http://nod.inf.ua

# Вмикає фонові daemon-и (скан, FF, funding…). true — ОБОВ'ЯЗКОВО для роботи бота.
ENABLE_SCHEDULER=true

# Миттєвий флаш логів у journald. Лишити 1.
PYTHONUNBUFFERED=1

# Порт gunicorn. МАЄ збігатися з upstream у nginx (127.0.0.1:10000).
PORT=10000


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  7. БАЗА ДАНИХ  (локальна на VDS, НЕ стара з Render)                        ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# ⚠️ Пароль БД зроби ОКРЕМИМ і сильним (НЕ таким, як ADMIN_PASSWORD).
DATABASE_URL=postgresql://botuser:<сильний_пароль_БД>@localhost:5432/botdb


# ╔════════════════════════════════════════════════════════════════════════════╗
# ║  8. ПОКАЗНИКИ / ФУНКЦІЇ (перемикачі)                                        ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# Read-only обхід /api/* за заголовком X-API-Key (інфо-сайт + TradingView-скрипт).
# Порожньо = обхід вимкнено. openssl rand -hex 24
INFO_API_KEY=<hex24_випадковий>

# Брати Binance у карту ліквідацій LIQMAP.  1 = увімк / 0 = вимк.
LIQMAP_USE_BINANCE=1

# Показувати CTR 1H / 4H у черзі та банері. 1 = увімк / 0 = вимк.
# Кожен увімкнений ТФ = +200 клайнів на монету (кеш 1H≈5хв, 4H≈15хв).
CTR_1H=1
CTR_4H=1

# 🎯 Професійна модель ММ (LIQMAP Liquidity-Pull + whale/стакан/funding).
# 1 = нова модель / 0 = стара (fa−fb)/den.
MM_MODEL=1

# Анти-залипання банера ₿: скид сеансу в ⚪ WAIT після N хв безперервної паузи
# (глибокий нейтрал). Діє лише при MM_MODEL=1. Варіанти: 30 / 45 / 60 / 90; 0 = вимкнути.
BTC_WAIT_RESET_MIN=45
